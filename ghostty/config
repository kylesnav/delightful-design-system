theme = delightful-light

# --- Typography ---
# Ghostty embeds JetBrains Mono, matching --font-mono.
# cv02–cv04, cv11 match the design system's font-feature-settings.
font-size = 14
font-thicken = true
font-feature = cv02
font-feature = cv03
font-feature = cv04
font-feature = cv11
font-style-bold = bold
font-style-bold-italic = bold italic
# adjust-cell-height = 20%


# --- Cursor ---
cursor-style = block
cursor-style-blink = false
# minimum-contrast = 1.3

# --- Window ---
window-padding-x = 16
window-padding-y = 12,8
window-padding-balance = true
window-theme = auto
macos-titlebar-style = tabs
window-save-state = always
unfocused-split-opacity = 0.9
window-decoration = server


# --- Behavior ---
clipboard-paste-protection = false
copy-on-select = clipboard
mouse-hide-while-typing = true
link-url = true
scrollback-limit = 10000000
shell-integration = zsh
shell-integration-features = sudo,title
command = /Users/kylesnav/.local/bin/tmux-auto-attach
macos-option-as-alt = true

# --- Keybinds ---
# Splits (equalized, vim-style navigation)
keybind = cmd+d=new_split:right
keybind = chain=equalize_splits
keybind = cmd+shift+d=new_split:down
keybind = chain=equalize_splits
